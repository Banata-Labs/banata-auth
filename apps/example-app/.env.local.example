# App URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Create this in the Banata dashboard after creating your project.
# The Next.js server injects it into auth proxy requests so the browser never sees it.
BANATA_API_KEY=sk_test_your_project_key

# Optional: override only if you use a custom Banata auth domain or self-hosted deployment.
# Hosted Banata apps default to https://auth.banata.dev
# BANATA_AUTH_URL=https://auth.yourcompany.com

# Optional legacy scope hints for self-hosted or partially migrated setups only:
# BANATA_CLIENT_ID=your-project-slug
# BANATA_PROJECT_ID=project_123
